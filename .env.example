# Local PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/breaddb

# Optional: super admin profile email for clan creation
SUPER_ADMIN_EMAIL=admin@example.com

# AI provider: "gemini" or "openai"
AI_PROVIDER=gemini

# Google Gemini API key (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API key (required when AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Stage failsafe: set to "true" to serve curated demo data from API routes (no AI calls)
# OFFLINE_BAKING_MODE=true

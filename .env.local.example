# =============================================================================
# BREAD — Local Environment Configuration (.env.local)
# =============================================================================
# Copy this file to the project root as `.env.local`:
#
#   cp .env.local.example .env.local
#
# Next.js automatically loads `.env.local` for `npm run dev` and `npm run build`.
# These variables are SERVER-ONLY (never exposed to the browser) unless prefixed
# with NEXT_PUBLIC_.
# =============================================================================

# --- AI Provider (pick one) ---
# "gemini" (recommended, free tier) or "openai"
AI_PROVIDER=gemini

# --- Google Gemini (required when AI_PROVIDER=gemini) ---
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- OpenAI (required when AI_PROVIDER=openai) ---
# Get a key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# --- Stage Failsafe (optional) ---
# When "true", API routes return curated pitch demo data instantly — no AI calls.
# Use as a server-side backup if venue Wi-Fi is unreliable.
# OFFLINE_BAKING_MODE=true

# --- Database (optional — not required for hackathon demo) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/breaddb
